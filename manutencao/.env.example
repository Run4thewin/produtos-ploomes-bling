# === Banco de dados ===
# Opção A (dev/local): URL completa.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/manutencao
# URL síncrona usada SOMENTE pelas migrações Alembic (driver psycopg).
# Se vazia, é derivada de DATABASE_URL trocando o driver para psycopg.
DATABASE_URL_SYNC=

# Opção B (Cloud Run + Cloud SQL): deixe DATABASE_URL vazio e informe as partes.
# A senha (DB_PASSWORD) vem do Secret Manager; INSTANCE_CONNECTION_NAME ativa o socket.
# DB_USER=manutencao
# DB_PASSWORD=troque
# DB_NAME=manutencao
# INSTANCE_CONNECTION_NAME=meu-projeto:us-central1:manutencao-db

# === Segurança / JWT ===
JWT_SECRET=troque-por-um-segredo-forte-em-producao
JWT_ALG=HS256
ACCESS_TOKEN_MIN=30
REFRESH_TOKEN_DAYS=7
RESET_TOKEN_MIN=30

# === App ===
DEBUG=true
